# App
APP_ENV=development
APP_NAME=FitCoach AI
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# LLM
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_MODEL=
OPENAI_TIMEOUT_SECONDS=20
OPENAI_INVALID_OUTPUT_RETRIES=2

# Vector database
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=fitcoach_knowledge

# Observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# App database
DATABASE_URL=sqlite:///./fitcoach_ai.db
