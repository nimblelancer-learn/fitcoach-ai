# App
APP_ENV=development
APP_NAME=FitCoach AI
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# LLM
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_MODEL=gpt-4.1-mini

# Vector database
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=fitcoach_knowledge

# Observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# App database
DATABASE_URL=sqlite:///./fitcoach_ai.db
